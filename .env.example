OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODELS=nvidia/nemotron-nano-9b-v2:free,z-ai/glm-4.5-air:free,openrouter/free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
ROUTE_LLM_TIMEOUT_SECONDS=45
ROUTE_LLM_MAX_TOKENS=700
ROUTE_LLM_TEMPERATURE=0.1

LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aviation-rag-team

RAG_TOP_K=10
RAG_RETRIEVAL_STRATEGY=hybrid
INTENT_CONF_THRESHOLD=0.55
INPUT_INTENT_MODE=auto
PHASE1_ML_CONFIDENCE_THRESHOLD=0.55
PHASE1_VALIDATION_SPLIT=0.2
PHASE1_USE_STEMMING=true
PHASE1_RETRAIN=false

RETRIEVAL_MAX_DOCS=15000
RETRIEVAL_TFIDF_MAX_FEATURES=12000
RETRIEVAL_SVD_COMPONENTS=128

PHASE2_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PHASE2_CHUNK_TOKENS=512
PHASE2_CHUNK_OVERLAP=50
PHASE2_INDEX_DIR=artifacts/phase2_index
PHASE2_HYBRID_MODE=weighted
PHASE2_SEMANTIC_BATCH_SIZE=64
# Human-labeled relevant ASRS event_id lists for Recall@K / MRR benchmark
# PHASE2_GOLD_LABELS_PATH=data/phase2_retrieval_gold_labels.jsonl
